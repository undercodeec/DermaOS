# Conexión Postgres local (pgAdmin / psql) — ajusta password y database
DATABASE_URL="postgresql://postgres:CHANGEME@127.0.0.1:5432/derma_os?schema=public"

# Secreto para firmar JWT (genera uno: openssl rand -hex 48)
JWT_SECRET="cambia-esto-por-un-secreto-largo-aleatorio"
JWT_EXPIRES_IN="12h"

# Carpeta donde se guardan fotos y firmas (relativa a apps/api)
UPLOAD_DIR="uploads"

# Origen permitido (CORS) — Vite dev server
CORS_ORIGIN="http://localhost:5173"

# Puerto del backend
PORT=4000

# Clave para proteger POST /clinics/register (genera con: openssl rand -hex 32)
PLATFORM_REGISTER_KEY="cambia-esto-por-un-secreto-largo-aleatorio"

# Módulo de facturación SRI (deshabilitado hasta integración con webservice SRI)
INVOICES_ENABLED=false
